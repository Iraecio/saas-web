{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/saas-web/browser",
  "serverlessFunctionRegion": "iad1",
  "functions": {
    "api/handler.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/handler"
    }
  ]
}
